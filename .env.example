# Copy to `.env` and fill in real values. `.env` is gitignored.
# In GitHub Actions, these are provided via repository secrets (same names).

# --- Meta Marketing API ---
META_ACCESS_TOKEN=

# --- Google Sheets ---
# Local: path to service-account JSON file
# GHA:   contents of the JSON are stored in secret GOOGLE_SERVICE_ACCOUNT_JSON
#        and the workflow writes it to this path before running scripts.
GOOGLE_SERVICE_ACCOUNT_FILE=google-service-account.json

# --- Shopify (per portal) ---
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_STORE_URL=studd-muffyn.myshopify.com
