# Meta WhatsApp Cloud API credentials — get these from developers.facebook.com → your App → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=set-a-random-string-here-and-paste-same-in-meta-webhook-config
WA_GRAPH_VERSION=v21.0

# Allowlist — comma-separated E.164 phone numbers (no +). Messages from anyone else are silently dropped.
# Example: 919517744959,917889166849,918283901380
ALLOWLIST=919517744959

# Path to the meta-ads-reports repo (the scripts/ dir). Used by router + claude_runner.
REPORTS_REPO=/Users/pulkitsharma/meta-ads-reports

# Claude Code binary path (uses your Max subscription via OAuth login in Keychain)
CLAUDE_BIN=/Users/pulkitsharma/.local/bin/claude

# Server port for the Flask app (Cloudflare Tunnel will point to this)
PORT=8080

# Log file
LOG_FILE=/Users/pulkitsharma/meta-ads-reports/whatsapp-bot/server.log
